                "value": 0
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 17
      },
      "id": 4,
      "options": {
        "displayMode": "lcd",
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "text": {},
        "valueMode": "color"
      },
      "pluginVersion": "12.4.1",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "exemplar": false,
          "expr": "sum by(task_name, task_order)(workflow_task_duration_seconds_sum{team_name=~\"$team\",workflow_name=~\"$workflow\",branch=~\"$branch\",status=\"SUCCESS\"}) / sum by(task_name, task_order)(workflow_task_duration_seconds_count{team_name=~\"$team\",workflow_name=~\"$workflow\",branch=~\"$branch\",status=\"SUCCESS\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Mean Task Duration by Stage (Successful Tasks)",
      "transformations": [
        {
          "id": "sortBy",
          "options": {
            "fields": [
              {
                "desc": false,
                "displayName": "task_order"
              }
            ],
            "sort": [
              {
                "field": "task_order"
              }
            ]
          }
        },
        {
          "id": "rowsToFields",
          "options": {
            "mappings": [
              {
                "fieldName": "task_order",
                "handlerKey": "__ignore"
              },
              {
                "fieldName": "Time",
                "handlerKey": "__ignore"
              },
              {
                "fieldName": "Value",
                "handlerKey": "field.value"
              },
              {
                "fieldName": "task_name",
                "handlerKey": "field.name"
              }
            ],
            "nameField": "task_name",
            "valueField": "Value"
          }
        }
      ],
      "type": "bargauge"
    }
  ],
