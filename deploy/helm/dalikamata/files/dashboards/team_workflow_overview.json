  },
  "description": "Recent build status, duration trends, and task breakdown for a single team.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "dalikamata-api"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "fillOpacity": 70,
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "lineWidth": 1
          },
          "displayName": "${__field.labels.workflow_name}/${__field.labels.branch}",
          "mappings": [
            {
              "options": {
                "ABORTED": {
                  "color": "text",
                  "index": 2,
                  "text": "ABORTED"
                },
                "FAILURE": {
                  "color": "red",
                  "index": 1,
                  "text": "FAILURE"
                },
                "SUCCESS": {
                  "color": "green",
                  "index": 0,
                  "text": "SUCCESS"
                },
                "UNSTABLE": {
                  "color": "yellow",
                  "index": 3,
                  "text": "UNSTABLE"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colWidth": 0.9,
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "rowHeight": 0.9,
        "showValue": "never",
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "columns": [
            {
              "selector": "started_at",
              "text": "started_at",
              "type": "string"
            },
            {
              "selector": "workflow_name",
              "text": "workflow_name",
              "type": "string"
            },
            {
              "selector": "branch",
              "text": "branch",
              "type": "string"
            },
            {
              "selector": "status",
              "text": "status",
              "type": "string"
            }
          ],
          "datasource": {
            "type": "yesoreyeram-infinity-datasource",
            "uid": "dalikamata-api"
          },
          "filterExpression": "workflow_name in (${workflow:singlequote})",
          "filters": [],
          "format": "table",
          "parser": "backend",
          "refId": "A",
          "root_selector": "hits",
          "source": "url",
          "type": "json",
          "url": "/api/v1/workflowRuns?filter.team_name=${team}&sort=-started_at&size=200",
          "url_options": {
            "data": "",
            "method": "GET"
          }
        }
      ],
      "title": "Recent Builds by Workflow \u2014 $team",
      "transformations": [
        {
          "id": "convertFieldType",
          "options": {
            "conversions": [
              {
                "destinationType": "time",
                "targetField": "started_at"
              }
            ]
          }
        },
        {
          "id": "partitionByValues",
          "options": {
            "fields": [
              "workflow_name",
              "branch"
            ],
            "keepFields": false
          }
        }
      ],
      "type": "status-history"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (workflow_name) (rate(workflow_run_duration_seconds_sum{team_name=~\"$team\",workflow_name=~\"$workflow\",branch=~\"$branch\",status=\"SUCCESS\"}[$__rate_interval])) / sum by (workflow_name) (rate(workflow_run_duration_seconds_count{team_name=~\"$team\",workflow_name=~\"$workflow\",branch=~\"$branch\",status=\"SUCCESS\"}[$__rate_interval]))",
          "legendFormat": "{{workflow_name}}",
          "refId": "A"
        }
      ],
      "title": "Workflow Run Duration (Successful Builds)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
