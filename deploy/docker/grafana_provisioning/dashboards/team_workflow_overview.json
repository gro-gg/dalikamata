                  "spec": {
                    "options": {
                      "mappings": [
                        {
                          "fieldName": "task_order",
                          "handlerKey": "__ignore"
                        },
                        {
                          "fieldName": "Time",
                          "handlerKey": "__ignore"
                        },
                        {
                          "fieldName": "Value",
                          "handlerKey": "field.value"
                        },
                        {
                          "fieldName": "task_name",
                          "handlerKey": "field.name"
                        }
                      ],
                      "nameField": "task_name",
                      "valueField": "Value"
                    }
                  }
                }
              ]
            }
          },
          "description": "",
          "id": 4,
          "links": [],
          "title": "Mean Task Duration by Stage (Successful Tasks)",
