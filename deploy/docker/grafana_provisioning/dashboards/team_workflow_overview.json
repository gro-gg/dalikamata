{
  "apiVersion": "dashboard.grafana.app/v2",
  "kind": "Dashboard",
  "metadata": {
    "name": "dalikamata-team-workflow-overview"
  },
  "spec": {
    "annotations": [
      {
        "kind": "AnnotationQuery",
        "spec": {
          "builtIn": true,
          "enable": true,
          "hide": true,
          "iconColor": "rgba(0, 211, 255, 1)",
          "name": "Annotations & Alerts",
          "query": {
            "datasource": {
              "name": "-- Grafana --"
            },
            "group": "grafana",
            "kind": "DataQuery",
            "spec": {},
            "version": "v0"
          }
        }
      }
    ],
    "cursorSync": "Crosshair",
    "description": "Recent build status, duration trends, and task breakdown for a single team.",
    "editable": true,
    "elements": {
      "panel-1": {
        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "datasource": {
                        "name": "dalikamata-api"
                      },
                      "group": "yesoreyeram-infinity-datasource",
                      "kind": "DataQuery",
                      "spec": {
                        "columns": [
                          {
                            "selector": "index",
                            "text": "Run Number",
                            "type": "string"
                          },
                          {
                            "selector": "status",
                            "text": "Status",
                            "type": "string"
                          },
                          {
                            "selector": "duration",
                            "text": "Duration",
                            "type": "string"
                          },
                          {
                            "selector": "workflow",
                            "text": "Name",
                            "type": "string"
                          },
                          {
                            "selector": "workflow_name",
                            "text": "workflow_name",
                            "type": "string"
                          },
                          {
                            "selector": "branch",
                            "text": "branch",
                            "type": "string"
                          },
                          {
                            "selector": "component_name",
                            "text": "component_name",
                            "type": "string"
                          }
                        ],
                        "computed_columns": [],
                        "filterExpression": "workflow_name in (${workflow:singlequote}) && branch in (${branch:singlequote})",
                        "filters": [],
                        "format": "table",
                        "global_query_id": "",
                        "parser": "backend",
                        "root_selector": "(\n    $makeRow := function($run, $wf, $idx) {\n        $run ? {\n            \"workflow\": $wf,\n            \"started_at\": $run.started_at,\n            \"status\": $run.status,\n            \"duration\": $run.duration,\n            \"index\": $idx,\n            \"workflow_name\": $run.workflow_name,\n            \"branch\": $run.branch,\n            \"component_name\": $run.component_name\n        } : {\n           \"index\": $idx,\n           \"workflow\": $wf,\n           \"workflow_name\": \"missing\"\n        }\n    };\n\n  $h := hits;\n  $d := hits ? $distinct(hits.($join([workflow_id,branch],'/'))) : null;\n  $d = null ? [] : ( $type($d) = \"string\" ? [$d] : $d );\n\n  $d.(\n      $wf := $;\n\n      $sorted := $h[$join([workflow_id, branch],'/') = $wf] ^(>number);\n  $sorted ?\n            [\n            $makeRow($sorted[9],$wf,9),\n            $makeRow($sorted[8],$wf,8),\n            $makeRow($sorted[7],$wf,7),\n            $makeRow($sorted[6],$wf,6),\n            $makeRow($sorted[3],$wf,5),\n            $makeRow($sorted[4],$wf,4),\n            $makeRow($sorted[5],$wf,3),\n            $makeRow($sorted[2],$wf,2),\n            $makeRow($sorted[1],$wf,1),\n            $makeRow($sorted[0],$wf,0)\n        ][ $ != null] : []\n  );\n)",
                        "source": "url",
                        "type": "json",
                        "url": "/api/v1/workflowRuns?filter.team_name=${team}&sort=-started_at&size=200",
                        "url_options": {
                          "data": "",
                          "method": "GET"
                        }
                      },
                      "version": "v0"
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": [
                {
                  "group": "filterFieldsByName",
                  "kind": "Transformation",
                  "spec": {
                    "options": {
                      "byVariable": false,
                      "include": {
                        "names": [
                          "Duration",
                          "Name",
                          "Run Number",
                          "Status"
                        ]
                      }
                    }
                  }
                },
                {
                  "group": "groupingToMatrix",
                  "kind": "Transformation",
                  "spec": {
                    "options": {
                      "columnField": "Run Number",
                      "emptyValue": "null",
                      "rowField": "Name",
                      "valueField": "Status"
                    }
                  }
                },
                {
                  "group": "sortBy",
                  "kind": "Transformation",
                  "spec": {
                    "options": {
                      "fields": {},
                      "sort": [
                        {
                          "field": "Name\\Run Number"
                        }
                      ]
                    }
                  }
                }
              ]
            }
          },
          "description": "",
          "id": 1,
          "links": [],
          "title": "Recent Builds by Workflow — $team",
          "vizConfig": {
            "group": "table",
            "kind": "VizConfig",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "color": {
                    "fixedColor": "transparent",
                    "mode": "fixed"
                  },
                  "custom": {
                    "align": "center",
                    "cellOptions": {
                      "mode": "basic",
                      "type": "color-background"
                    },
                    "footer": {
                      "reducers": []
                    },
                    "inspect": false,
                    "minWidth": 50,
                    "styleField": "",
                    "width": 90
                  },
                  "fieldMinMax": false,
                  "mappings": [
                    {
                      "options": {
                        "ABORTED": {
                          "color": "text",
                          "index": 2,
                          "text": "ABORTED"
                        },
                        "FAILURE": {
                          "color": "red",
                          "index": 1,
                          "text": "FAILURE"
                        },
                        "SUCCESS": {
                          "color": "green",
                          "index": 0,
                          "text": "SUCCESS"
                        },
                        "UNSTABLE": {
                          "color": "yellow",
                          "index": 3,
                          "text": "UNSTABLE"
                        }
                      },
                      "type": "value"
                    }
                  ],
                  "thresholds": {
                    "mode": "absolute",
                    "steps": [
                      {
                        "color": "blue",
                        "value": 0
                      }
                    ]
                  }
                },
                "overrides": [
                  {
                    "matcher": {
                      "id": "byName",
                      "options": "Name\\Run Number",
                      "scope": "series"
                    },
                    "properties": [
                      {
                        "id": "custom.width",
                        "value": 240
                      }
                    ]
                  }
                ]
              },
              "options": {
                "cellHeight": "sm",
                "showHeader": false,
                "sortBy": []
              }
            },
            "version": "13.1.0"
          }
        }
      },
      "panel-2": {
        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "datasource": {
                        "name": "prometheus"
                      },
                      "group": "prometheus",
                      "kind": "DataQuery",
                      "spec": {
                        "editorMode": "code",
                        "expr": "sum by (workflow_name) (rate(workflow_run_duration_seconds_sum{team_name=~\"$team\",workflow_name=~\"$workflow\",branch=~\"$branch\",status=\"SUCCESS\"}[$__rate_interval])) / sum by (workflow_name) (rate(workflow_run_duration_seconds_count{team_name=~\"$team\",workflow_name=~\"$workflow\",branch=~\"$branch\",status=\"SUCCESS\"}[$__rate_interval]))",
                        "legendFormat": "{{workflow_name}}"
                      },
                      "version": "v0"
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
          },
          "description": "",
          "id": 2,
          "links": [],
          "title": "Workflow Run Duration (Successful Builds)",
          "vizConfig": {
            "group": "timeseries",
            "kind": "VizConfig",
