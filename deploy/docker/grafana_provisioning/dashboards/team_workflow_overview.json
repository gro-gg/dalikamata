                        "expr": "sum by(task_name, task_order)(workflow_task_duration_seconds_sum{team_name=~\"$team\",workflow_name=~\"$workflow\",branch=~\"$branch\",status=\"SUCCESS\"}) / sum by(task_name, task_order)(workflow_task_duration_seconds_count{team_name=~\"$team\",workflow_name=~\"$workflow\",branch=~\"$branch\",status=\"SUCCESS\"})",
                        "format": "table",
                        "instant": true,
                        "legendFormat": "__auto",
                        "range": false
                      },
                      "version": "v0"
                    },
                    "refId": "A"
